<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <!-- =========================
             RAIL VALIDATOR FORM VIEW
             ========================= -->
        <record id="view_rail_validator_form" model="ir.ui.view">
            <field name="name">rail.consignment.validator.form</field>
            <field name="model">rail.consignment.validator</field>
            <field name="arch" type="xml">
                <form string="Rail and Container Validator">
                    <sheet>
                        <group>
                            <field name="name" invisible="1"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- =========================
             RAIL COMPANY CODE LIST VIEW
             ========================= -->
        <record id="view_rail_company_code_list" model="ir.ui.view">
            <field name="name">rail.company.code.list</field>
            <field name="model">rail.company.code</field>
            <field name="arch" type="xml">
                <list string="Company Codes (RICS)">
                    <field name="code"/>
                    <field name="short_name"/>
                    <field name="full_name"/>
                    <field name="country"/>
                    <field name="url"/>
                </list>
            </field>
        </record>

        <!-- =========================
             RAIL COMPANY CODE FORM VIEW
             ========================= -->
        <record id="view_rail_company_code_form" model="ir.ui.view">
            <field name="name">rail.company.code.form</field>
            <field name="model">rail.company.code</field>
            <field name="arch" type="xml">
                <form string="Company Codes (RICS)">
                    <sheet>
                        <group>
                            <group>
                                <field name="code"/>
                                <field name="short_name"/>
                                <field name="country"/>
                            </group>
                            <group>
                                <field name="full_name"/>
                                <field name="url"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- =========================
             ACTIONS
             ========================= -->
        <record id="action_rail_validator" model="ir.actions.act_window">
            <field name="name">Rail and Container Validator</field>
            <field name="res_model">rail.consignment.validator</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="view_rail_validator_form"/>
            <field name="target">current</field>
        </record>

        <record id="action_rail_company_codes" model="ir.actions.act_window">
            <field name="name">Company Codes (RICS)</field>
            <field name="res_model">rail.company.code</field>
            <field name="view_mode">list,form</field>
            <field name="target">current</field>
        </record>

        <!-- =========================
             MENUS
             ========================= -->
        <menuitem id="menu_rail_root"
                  name="Rail Tools"
                  sequence="10"/>

        <menuitem id="menu_rail_validator"
                  name="Rail and Container Validator"
                  parent="menu_rail_root"
                  action="action_rail_validator"
                  sequence="10"/>

        <menuitem id="menu_rail_company_codes"
                  name="Company Codes (RICS)"
                  parent="menu_rail_root"
                  action="action_rail_company_codes"
                  sequence="20"/>

    </data>
</odoo>
