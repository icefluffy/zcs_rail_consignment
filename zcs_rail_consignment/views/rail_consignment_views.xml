<odoo>

    <record id="action_rail_validator" model="ir.actions.act_window">
        <field name="name">Rail and Container Validator</field>
        <field name="res_model">rail.consignment.validator</field>
        <field name="view_mode">form</field>
    </record>

    <record id="rail_validator_form" model="ir.ui.view">
        <field name="name">rail.consignment.validator.form</field>
        <field name="model">rail.consignment.validator</field>
        <field name="arch" type="xml">
            <form string="Validate Voorwerp">
                <sheet>
<group>
    <field name="voorwerp_nummer"/>
    <field name="valid_evn" readonly="1"/>
    <field name="type_code" readonly="1"/>
    <field name="type_desc" readonly="1"/>
    <field name="country_code" readonly="1"/>
    <field name="country_name" readonly="1"/>
<!--    <field name="company_code" readonly="1"/> -->
<!--    <field name="company_short_name" readonly="1"/> -->
<!--    <field name="company_full_name" readonly="1"/> -->
<!--    <field name="keeper_code" readonly="1"/> -->
    <field name="serial_number" readonly="1"/>
    <field name="check_digit" readonly="1"/>
    <field name="error_message" readonly="1"/>
</group>
<footer>
    <button name="action_validate_voorwerp" type="object" string="Validate" class="btn-primary"/>
</footer>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
