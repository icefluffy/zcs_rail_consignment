<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>



        <record id="view_rail_uic_wagon_form" model="ir.ui.view">
            <field name="name">rail.uic.wagon.form</field>
            <field name="model">rail.uic.wagon</field>
            <field name="arch" type="xml">
                <form string="UIC Wagon Decoder">
                    <sheet>
                        <group string="Input">
                            <field name="uic_evn"/>
                        </group>
                        <group string="Output">
                            <field name="uic_interoperability_code" readonly="1"/>
                            <field name="uic_wagon_category" readonly="1"/>
                        </group>
                        <group string="Country">
                            <field name="uic_country_code" readonly="1"/>
                            <field name="uic_country_name" readonly="1"/>
                            <field name="uic_country_letter" readonly="1"/>
                        </group>
                        <group string="Interoperability"
                            invisible="uic_wagon_category != 'freight'">
                            <field name="uic_freight_wagon_type" readonly="1"/>
                            <field name="uic_gauge_type" readonly="1"/>
                            <field name="uic_axle_type" readonly="1"/>
                        </group>
                        <group string="Category"
                            invisible="uic_wagon_category != 'freight'">
                            <field name="uic_wagon_class_number" readonly="1"/>
                            <field name="uic_wagon_class_letter" readonly="1"/>
                            <field name="uic_wagon_class_desc" readonly="1"/>
                            <field name="uic_freight_letter_codes" readonly="1"/>
                        </group>
                        <group string="Dimensions"
                            invisible="uic_wagon_category != 'freight'">
                            <field name="uic_max_speed" readonly="1"/>
                            <field name="uic_load_capacity" readonly="1"/>
                            <!-- uic_axle_count: human-readable label, includes
                                 "(inferred, bogie)" suffix when derived from d0d1
                                 rather than an explicit ERA P9 letter code. -->
                            <field name="uic_axle_count" readonly="1"/>
                            <!-- uic_axle_count_int: numeric value for summation
                                 across wagon lines in a consignment. Hidden on the
                                 decoder form but used by consignment totals. -->
                            <field name="uic_axle_count_int" readonly="1" invisible="1"/>
                        </group>
                        <group string="Validation">
                            <field name="uic_decode_valid" readonly="1"/>
                            <field name="uic_check_digit_ok" readonly="1"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>



        <!-- List view: uic_axle_count added for at-a-glance axle info. -->
        <record id="view_rail_uic_wagon_list" model="ir.ui.view">
            <field name="name">rail.uic.wagon.list</field>
            <field name="model">rail.uic.wagon</field>
            <field name="arch" type="xml">
                <list string="UIC Wagon Lookups">
                    <field name="name"/>
                    <field name="uic_evn"/>
                    <field name="uic_country_name"/>
                    <field name="uic_wagon_category"/>
                    <field name="uic_freight_letter_codes"/>
                    <field name="uic_axle_count"/>
                    <field name="uic_check_digit_ok"/>
                </list>
            </field>
        </record>



        <record id="action_rail_uic_wagon" model="ir.actions.act_window">
            <field name="name">UIC Wagon Decoder</field>
            <field name="res_model">rail.uic.wagon</field>
            <field name="view_mode">form</field>
            <field name="target">current</field>
        </record>



    </data>
</odoo>
